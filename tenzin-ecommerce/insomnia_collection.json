{
  "_type": "export",
  "__export_format": 4,
  "__export_source": "tenzin-ecommerce-microservices",
  "resources": [
    {
      "_id": "wrk_ecommerce",
      "_type": "workspace",
      "name": "E-commerce Microsserviços",
      "description": "Coleção de requisições para os 5 microsserviços (Product, User, Inventory, Payment, Order)."
    },
    {
      "_id": "env_base",
      "_type": "environment",
      "parentId": "wrk_ecommerce",
      "name": "Base",
      "data": {
        "product_url": "http://localhost:3001",
        "user_url": "http://localhost:3002",
        "inventory_url": "http://localhost:3003",
        "payment_url": "http://localhost:3004",
        "order_url": "http://localhost:3005"
      }
    },
    {
      "_id": "grp_cenario1",
      "_type": "request_group",
      "parentId": "wrk_ecommerce",
      "name": "Cenário 1 - Sucesso (fluxo completo)"
    },
    {
      "_id": "req_c1_produto",
      "_type": "request",
      "parentId": "grp_cenario1",
      "name": "1. Criar produto",
      "method": "POST",
      "url": "{{ _.product_url }}/products",
      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"name\": \"Camiseta Tenzin\",\n  \"description\": \"Algodão premium\",\n  \"price\": 50\n}"
      },
      "headers": [{ "name": "Content-Type", "value": "application/json" }],
      "metaSortKey": -100
    },
    {
      "_id": "req_c1_usuario",
      "_type": "request",
      "parentId": "grp_cenario1",
      "name": "2. Criar usuário",
      "method": "POST",
      "url": "{{ _.user_url }}/users",
      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"name\": \"Siddarta\",\n  \"email\": \"sid@example.com\"\n}"
      },
      "headers": [{ "name": "Content-Type", "value": "application/json" }],
      "metaSortKey": -90
    },
    {
      "_id": "req_c1_estoque",
      "_type": "request",
      "parentId": "grp_cenario1",
      "name": "3. Cadastrar estoque inicial (produto 1 = 10)",
      "method": "PUT",
      "url": "{{ _.inventory_url }}/inventory/1",
      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"quantity\": 10\n}"
      },
      "headers": [{ "name": "Content-Type", "value": "application/json" }],
      "metaSortKey": -80
    },
    {
      "_id": "req_c1_pedido",
      "_type": "request",
      "parentId": "grp_cenario1",
      "name": "4. Criar pedido (2 unidades) -> PAGO",
      "method": "POST",
      "url": "{{ _.order_url }}/orders",
      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"userId\": 1,\n  \"items\": [\n    { \"productId\": 1, \"quantity\": 2 }\n  ]\n}"
      },
      "headers": [{ "name": "Content-Type", "value": "application/json" }],
      "metaSortKey": -70
    },
    {
      "_id": "req_c1_status",
      "_type": "request",
      "parentId": "grp_cenario1",
      "name": "5. Consultar status do pedido",
      "method": "GET",
      "url": "{{ _.order_url }}/orders/1",
      "metaSortKey": -60
    },
    {
      "_id": "req_c1_estoque_apos",
      "_type": "request",
      "parentId": "grp_cenario1",
      "name": "6. Conferir estoque após baixa (esperado 8)",
      "method": "GET",
      "url": "{{ _.inventory_url }}/inventory/1",
      "metaSortKey": -50
    },
    {
      "_id": "grp_cenario2",
      "_type": "request_group",
      "parentId": "wrk_ecommerce",
      "name": "Cenário 2 - Falha controlada (estoque insuficiente)"
    },
    {
      "_id": "req_c2_pedido",
      "_type": "request",
      "parentId": "grp_cenario2",
      "name": "Criar pedido com qtd > estoque -> 422 (rejeitado)",
      "method": "POST",
      "url": "{{ _.order_url }}/orders",
      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"userId\": 1,\n  \"items\": [\n    { \"productId\": 1, \"quantity\": 9999 }\n  ]\n}"
      },
      "headers": [{ "name": "Content-Type", "value": "application/json" }],
      "metaSortKey": -40
    },
    {
      "_id": "grp_avulsos",
      "_type": "request_group",
      "parentId": "wrk_ecommerce",
      "name": "Endpoints avulsos"
    },
    {
      "_id": "req_av_listar_produtos",
      "_type": "request",
      "parentId": "grp_avulsos",
      "name": "GET produtos",
      "method": "GET",
      "url": "{{ _.product_url }}/products",
      "metaSortKey": -30
    },
    {
      "_id": "req_av_produto_id",
      "_type": "request",
      "parentId": "grp_avulsos",
      "name": "GET produto por ID",
      "method": "GET",
      "url": "{{ _.product_url }}/products/1",
      "metaSortKey": -25
    },
    {
      "_id": "req_av_usuario_id",
      "_type": "request",
      "parentId": "grp_avulsos",
      "name": "GET usuário por ID",
      "method": "GET",
      "url": "{{ _.user_url }}/users/1",
      "metaSortKey": -20
    },
    {
      "_id": "req_av_pagamento",
      "_type": "request",
      "parentId": "grp_avulsos",
      "name": "POST pagamento (teste direto)",
      "method": "POST",
      "url": "{{ _.payment_url }}/payments",
      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"orderId\": 1,\n  \"amount\": 100\n}"
      },
      "headers": [{ "name": "Content-Type", "value": "application/json" }],
      "metaSortKey": -10
    }
  ]
}
